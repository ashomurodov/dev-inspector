{
  "name": "aetherx-ui-inspector",
  "version": "1.4.6",
  "description": "Universal dev-only UI inspector with live editing and feedback clipboard",
  "type": "module",
  "main": "index.js",
  "module": "index.js",
  "types": "./index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashomurodov/dev-inspector.git"
  },
  "homepage": "https://github.com/ashomurodov/dev-inspector#readme",
  "bugs": {
    "url": "https://github.com/ashomurodov/dev-inspector/issues"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./react": {
      "types": "./react/index.d.ts",
      "default": "./react/index.jsx"
    },
    "./vue": {
      "types": "./vue/index.d.ts",
      "default": "./vue/index.vue"
    },
    "./auto": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "files": [
    "src",
    "react",
    "vue",
    "index.js",
    "index.d.ts"
  ],
  "keywords": [
    "dev",
    "inspector",
    "ui",
    "debug",
    "design",
    "feedback",
    "css"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
