{
  "name": "aetherx-ui-inspector",
  "version": "1.4.9",
  "description": "Universal dev-only UI inspector with live editing and feedback clipboard",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashomurodov/dev-inspector.git"
  },
  "homepage": "https://github.com/ashomurodov/dev-inspector#readme",
  "bugs": {
    "url": "https://github.com/ashomurodov/dev-inspector/issues"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./react/index.d.ts",
      "default": "./dist/react.js"
    },
    "./vue": {
      "types": "./vue/index.d.ts",
      "default": "./dist/vue.js"
    },
    "./auto": {
      "types": "./index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "index.d.ts",
    "vue/index.d.ts",
    "react/index.d.ts"
  ],
  "scripts": {
    "build": "rollup -c"
  },
  "keywords": [
    "dev",
    "inspector",
    "ui",
    "debug",
    "design",
    "feedback",
    "css"
  ],
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "rollup": "^4.0.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
